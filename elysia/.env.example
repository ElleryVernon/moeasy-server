# Elysia 환경 변수 예시
# 주석 삭제 금지, 주석 추가 및 개선은 허용

PORT=3000
JWT_SECRET_KEY=replace-with-your-jwt-secret

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_QR_BUCKET=your-qr-bucket
S3_PROFILE_BUCKET=your-profile-bucket

URL_SIGNER_SECRET_KEY=replace-with-url-signer-secret
URL_SIGNER_ALGORITHM=HmacSHA256

DYNAMODB_TABLE_PREFIX=moeasy

